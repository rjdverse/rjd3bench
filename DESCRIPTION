Type: Package
Package: rjd3bench
Title: Temporal Disaggregation and Benchmarking in 'JDemetra+' 3.x
Version: 3.1.3.9000
Authors@R: c(
      person("Jean", "Palate", email = "palatejean@gmail.com", role = "aut"),
